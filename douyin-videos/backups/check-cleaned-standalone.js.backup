import * as fs from "fs";
import * as path from "path";

const PROJECT_ROOT = "d:\\opencli\\douyin-videos";
const DEFAULT_DATA_DIR = "d:\\opencli\\douyin-videos\\data";

const REQUIRED_FIELDS = [
  "video_id",
  "url",
  "author",
  "author_id",
  "title",
  "analyzed_at",
  "quality",
  "topic",
  "main_content",
];

function readVideos(dataDir) {
  const filePath = path.join(dataDir, "videos.json");
  if (!fs.existsSync(filePath)) {
    return { version: "1.0", updated_at: new Date().toISOString(), videos: [] };
  }
  try {
    const content = fs.readFileSync(filePath, "utf-8");
    const data = JSON.parse(content);
    if (!data.videos) {
      data.videos = [];
    }
    return data;
  } catch (error) {
    console.error("读取视频列表失败:", error.message);
    return { version: "1.0", updated_at: new Date().toISOString(), videos: [] };
  }
}

function findBloggerDir(author, secUid, resultsDir) {
  if (!fs.existsSync(resultsDir)) return null;
  
  const dirs = fs.readdirSync(resultsDir, { withFileTypes: true });
  const bloggerDirs = dirs.filter(d => d.isDirectory());
  
  const sanitizedName = author
    .replace(/[\/\\?%*:|"<>（）()【】\[\]{}]/g, '_')
    .replace(/\s+/g, '_')
    .replace(/_{2,}/g, '_')
    .replace(/^_|_$/g, '');
  
  for (const dir of bloggerDirs) {
    if (dir.name.startsWith(sanitizedName + "_")) {
      return dir.name;
    }
  }
  
  if (secUid) {
    for (const prefixLen of [10, 9, 8]) {
      const secUidPrefix = secUid.substring(0, prefixLen);
      for (const dir of bloggerDirs) {
        if (dir.name.includes(`_${secUidPrefix}`)) {
          return dir.name;
        }
      }
    }
  }
  
  for (const dir of bloggerDirs) {
    if (dir.name.includes(sanitizedName)) {
      return dir.name;
    }
  }
  
  return null;
}

function validateJsonFile(jsonPath) {
  const result = {
    exists: false,
    validJson: false,
    fieldsComplete: false,
    missingFields: [],
    contentLength: 0,
    topicLength: 0,
    error: null,
    titleMatch: null,
    authorIdMatch: null,
  };

  if (!fs.existsSync(jsonPath)) {
    result.error = "JSON文件不存在";
    return result;
  }
  result.exists = true;

  try {
    const content = fs.readFileSync(jsonPath, "utf-8");
    const json = JSON.parse(content);
    result.validJson = true;

    const missingFields = REQUIRED_FIELDS.filter(field => !json[field]);
    result.missingFields = missingFields;
    result.fieldsComplete = missingFields.length === 0;

    if (json.main_content) {
      result.contentLength = json.main_content.length;
    }
    if (json.topic) {
      result.topicLength = json.topic.length;
    }
    
    result._json = json;
  } catch (e) {
    result.error = `JSON解析失败: ${e.message}`;
  }

  return result;
}

function validateMetadataConsistency(videoJson, bloggerDir, resultsDir) {
  const result = {
    titleMatch: null,
    authorIdMatch: null,
    originalTitle: null,
    originalAuthorId: null,
    videoTitle: videoJson.title,
    videoAuthorId: videoJson.author_id,
    warnings: [],
  };
  
  if (!bloggerDir) {
    result.warnings.push("无法定位博主目录，跳过一致性检查");
    return result;
  }
  
  const metadataPath = path.join(resultsDir, bloggerDir, "metadata.json");
  if (!fs.existsSync(metadataPath)) {
    result.warnings.push("metadata.json 不存在，跳过一致性检查");
    return result;
  }
  
  try {
    const metadata = JSON.parse(fs.readFileSync(metadataPath, "utf-8"));
    const videoMeta = metadata.videos?.find(v => v.aweme_id === videoJson.video_id);
    
    if (videoMeta) {
      result.originalTitle = videoMeta.title;
      result.originalAuthorId = videoMeta.author_id || metadata.blogger_id;
      
      if (result.originalTitle) {
        result.titleMatch = videoJson.title === result.originalTitle;
        if (!result.titleMatch) {
          result.warnings.push(`标题不一致: 视频 JSON 使用 "${videoJson.title?.substring(0, 30)}..." vs 原始 "${result.originalTitle?.substring(0, 30)}..."`);
        }
      }
      
      if (result.originalAuthorId) {
        result.authorIdMatch = videoJson.author_id === result.originalAuthorId;
        if (!result.authorIdMatch) {
          result.warnings.push(`author_id 不一致: 视频 JSON "${videoJson.author_id}" vs 原始 "${result.originalAuthorId}"`);
        }
      }
    } else {
      result.warnings.push("在 metadata.json 中找不到该视频记录");
    }
  } catch (e) {
    result.warnings.push(`读取 metadata.json 失败: ${e.message}`);
  }
  
  return result;
}

function validateTranscript(transcriptPath) {
  const result = {
    exists: false,
    length: 0,
    error: null,
  };

  if (!fs.existsSync(transcriptPath)) {
    result.error = "转录文件不存在";
    return result;
  }
  result.exists = true;
  result.length = fs.readFileSync(transcriptPath, "utf-8").length;
  return result;
}

function deduplicateTranscript(transcriptText) {
  const lines = transcriptText.split("\n").filter((l) => l.trim());
  const uniqueLines = [...new Set(lines)];
  const totalNonEmpty = lines.length;
  const uniqueCount = uniqueLines.length;
  const duplicateRatio =
    totalNonEmpty > 0 ? (1 - uniqueCount / totalNonEmpty) : 0;
  const dedupText = uniqueLines.join("");
  return {
    originalLength: transcriptText.length,
    dedupLength: dedupText.length,
    totalLines: totalNonEmpty,
    uniqueLines: uniqueCount,
    duplicateRatio,
    dedupText,
  };
}

function compareContent(transcriptText, mainContent) {
  const dedup = deduplicateTranscript(transcriptText);

  const result = {
    transcriptLength: transcriptText.length,
    dedupTranscriptLength: dedup.dedupLength,
    contentLength: mainContent.length,
    compressionRatio: 0,
    dedupCompressionRatio: 0,
    duplicateRatio: dedup.duplicateRatio,
    totalLines: dedup.totalLines,
    uniqueLines: dedup.uniqueLines,
    warnings: [],
  };

  if (transcriptText.length > 0) {
    result.compressionRatio = mainContent.length / transcriptText.length;
  }

  if (dedup.dedupLength > 0) {
    result.dedupCompressionRatio = mainContent.length / dedup.dedupLength;
  }

  if (result.compressionRatio > 1.5) {
    result.warnings.push(
      `内容膨胀: 整理后内容比原始转录长${((result.compressionRatio - 1) * 100).toFixed(0)}%`
    );
  }

  if (dedup.duplicateRatio > 0.3) {
    result.warnings.push(
      `转录重复: 原始${dedup.totalLines}行中仅${dedup.uniqueLines}行唯一，重复率${(dedup.duplicateRatio * 100).toFixed(0)}%`
    );
  }

  const effectiveRatio = result.dedupCompressionRatio || result.compressionRatio;
  if (effectiveRatio < 0.3) {
    result.warnings.push(
      `内容过度压缩: 整理后内容仅为去重转录的${(effectiveRatio * 100).toFixed(0)}%`
    );
  }

  return result;
}

function parseArgs() {
  const args = process.argv.slice(2);
  const kwargs = {
    data_dir: DEFAULT_DATA_DIR,
    video_id: null,
  };

  for (let i = 0; i < args.length; i++) {
    if (args[i] === "--data_dir" && i + 1 < args.length) {
      kwargs.data_dir = args[i + 1];
      i++;
    } else if (args[i] === "--video_id" && i + 1 < args.length) {
      kwargs.video_id = args[i + 1];
      i++;
    }
  }

  return kwargs;
}

async function main() {
  const kwargs = parseArgs();
  const dataDir = kwargs.data_dir || DEFAULT_DATA_DIR;
  const videoIdFilter = kwargs.video_id
    ? new Set(kwargs.video_id.split(",").map((id) => id.trim()))
    : null;

  const resultsDir = path.join(PROJECT_ROOT, "results");
  const transcriptsDir = path.join(PROJECT_ROOT, "transcripts");

  console.log("=== 整理内容检查工具 ===\n");
  console.log(`数据目录: ${dataDir}`);
  console.log(`结果目录: ${resultsDir}\n`);

  const videosData = readVideos(dataDir);
  const cleanedVideos = videosData.videos.filter(
    (v) => v.stage4_status === "cleaned" && v.status === "processed"
  );

  let filteredVideos = cleanedVideos;
  if (videoIdFilter) {
    filteredVideos = cleanedVideos.filter((v) => videoIdFilter.has(v.aweme_id));
  }

  if (filteredVideos.length === 0) {
    console.log("没有已整理的视频需要检查");
    return;
  }

  console.log(`找到 ${filteredVideos.length} 个已整理视频\n`);

  const results = [];
  let passed = 0;
  let failed = 0;
  let warnings = 0;

  for (let i = 0; i < filteredVideos.length; i++) {
    const video = filteredVideos[i];
    const videoId = video.aweme_id;

    console.log(`\n[${i + 1}/${filteredVideos.length}] 检查: ${videoId}`);
    console.log(`  博主: ${video.author}`);
    console.log(`  标题: ${video.title?.substring(0, 40)}...`);

    const bloggerDir = findBloggerDir(video.author, video.sec_uid, resultsDir);
    if (!bloggerDir) {
      console.log(`  ❌ 找不到博主目录`);
      failed++;
      results.push({
        video_id: videoId,
        json_status: "missing_dir",
        fields: "-",
        content_len: "-",
        ratio: "-",
        status: "❌ 博主目录不存在",
      });
      continue;
    }

    const jsonPath = path.join(resultsDir, bloggerDir, "videos", `${videoId}.json`);
    const transcriptPath = path.join(transcriptsDir, `${videoId}.txt`);

    const jsonResult = validateJsonFile(jsonPath);
    const transcriptResult = validateTranscript(transcriptPath);

    if (!jsonResult.exists) {
      console.log(`  ❌ ${jsonResult.error}`);
      failed++;
      results.push({
        video_id: videoId,
        json_status: "missing",
        fields: "-",
        content_len: "-",
        ratio: "-",
        status: "❌ JSON文件不存在",
      });
      continue;
    }

    if (!jsonResult.validJson) {
      console.log(`  ❌ ${jsonResult.error}`);
      failed++;
      results.push({
        video_id: videoId,
        json_status: "invalid_json",
        fields: "-",
        content_len: "-",
        ratio: "-",
        status: "❌ JSON格式错误",
      });
      continue;
    }

    if (!jsonResult.fieldsComplete) {
      console.log(`  ❌ 缺少字段: ${jsonResult.missingFields.join(", ")}`);
      failed++;
      results.push({
        video_id: videoId,
        json_status: "incomplete",
        fields: jsonResult.missingFields.length.toString(),
        content_len: jsonResult.contentLength.toString(),
        ratio: "-",
        status: `❌ 缺少${jsonResult.missingFields.length}个字段`,
      });
      continue;
    }

    const consistencyResult = validateMetadataConsistency(jsonResult._json, bloggerDir, resultsDir);
    if (consistencyResult.warnings.length > 0) {
      for (const w of consistencyResult.warnings) {
        console.log(`  ⚠️ ${w}`);
      }
      warnings++;
    }

    let comparisonResult = null;
    let ratio = "-";
    let dedupRatio = "-";
    if (transcriptResult.exists) {
      const transcriptText = fs.readFileSync(transcriptPath, "utf-8");
      const json = JSON.parse(fs.readFileSync(jsonPath, "utf-8"));
      comparisonResult = compareContent(transcriptText, json.main_content);
      ratio = comparisonResult.compressionRatio.toFixed(2);
      dedupRatio = comparisonResult.dedupCompressionRatio.toFixed(2);

      if (comparisonResult.warnings.length > 0) {
        console.log(`  ⚠️ ${comparisonResult.warnings.join("; ")}`);
        warnings++;
      }
    }

    console.log(`  ✅ 检查通过`);
    console.log(`     主题长度: ${jsonResult.topicLength} 字符`);
    console.log(`     内容长度: ${jsonResult.contentLength} 字符`);
    if (comparisonResult) {
      console.log(`     原始压缩比: ${ratio}`);
      console.log(`     去重压缩比: ${dedupRatio}`);
      if (comparisonResult.duplicateRatio > 0.05) {
        console.log(`     转录重复率: ${(comparisonResult.duplicateRatio * 100).toFixed(0)}% (${comparisonResult.uniqueLines}/${comparisonResult.totalLines}行)`);
      }
    }
    passed++;

    results.push({
      video_id: videoId,
      json_status: "ok",
      fields: "9/9",
      content_len: jsonResult.contentLength.toString(),
      ratio: ratio,
      dedup_ratio: dedupRatio,
      status: comparisonResult?.warnings.length > 0 ? "⚠️ 有警告" : "✅ 通过",
    });
  }

  console.log("\n=== 检查完成 ===");
  console.log(`总计: ${filteredVideos.length}`);
  console.log(`通过: ${passed}`);
  console.log(`警告: ${warnings}`);
  console.log(`失败: ${failed}`);

  console.log("\n--- 结果列表 ---");
  for (const r of results) {
    console.log(`- video_id: '${r.video_id}'`);
    console.log(`  json_status: ${r.json_status}`);
    console.log(`  fields: ${r.fields}`);
    console.log(`  content_len: '${r.content_len}'`);
    console.log(`  ratio: '${r.ratio}'`);
    console.log(`  dedup_ratio: '${r.dedup_ratio}'`);
    console.log(`  status: ${r.status}`);
  }
}

main().catch(console.error);
